# EVOLVE-BLOCK-START
from skydiscover.search.base_database import Program, ProgramDatabase
from skydiscover.config import DatabaseConfig
from typing import Optional, Tuple, List, Dict
import logging
from dataclasses import dataclass
import random

logger = logging.getLogger(__name__)

@dataclass
class EvolvedProgram(Program):
    """Program for the evolved database."""
    

class EvolvedProgramDatabase(ProgramDatabase):
    """Initial search strategy database."""

    def __init__(self, name: str, config: DatabaseConfig):
        super().__init__(name, config)
        self.initial_program = None

        if config.random_seed is not None:
            random.seed(config.random_seed)
            logger.debug(f"Database: Set random seed to {config.random_seed}")

    def add(self, program: EvolvedProgram, iteration: Optional[int] = None, **kwargs) -> str:
        """Add a program to the database."""
        if iteration == 0 or program.iteration_found == 0:
            self.initial_program = program
        
        self.programs[program.id] = program

        if iteration is not None:
            self.last_iteration = max(self.last_iteration, iteration)

        if self.config.db_path:
            self._save_program(program)

        self._update_best_program(program)

        logger.debug(f"Added program {program.id} to the evolve database")
        return program.id

    def sample(
        self, 
        num_inspirations: Optional[int] = 4,
        **kwargs
    ) -> Tuple[Dict[str, EvolvedProgram], Dict[str, List[EvolvedProgram]]]:
        """
        Score-weighted sampling: selects parent via tournament selection favoring
        high-scoring programs, and inspirations via a mix of top performers and
        random diversity to balance exploitation and exploration.
        """
        candidates = list(self.programs.values())
        
        if len(candidates) == 0:
            raise ValueError("No candidates available for sampling")

        def get_score(p):
            """Extract numeric score, defaulting to 0."""
            try:
                return float(p.score) if p.score is not None else 0.0
            except (TypeError, ValueError):
                return 0.0

        # Tournament selection for parent: pick best of k random candidates
        tournament_size = min(3, len(candidates))
        tournament = random.sample(candidates, tournament_size)
        parent = max(tournament, key=get_score)

        # For inspirations: mix top programs and random ones for diversity
        remaining = [p for p in candidates if p.id != parent.id]
        
        if len(remaining) == 0:
            examples = []
        else:
            num_top = max(1, num_inspirations // 2)
            num_rand = num_inspirations - num_top

            sorted_candidates = sorted(remaining, key=get_score, reverse=True)
            top_programs = sorted_candidates[:num_top]

            rand_pool = sorted_candidates[num_top:]
            rand_programs = random.sample(rand_pool, min(num_rand, len(rand_pool)))

            examples = top_programs + rand_programs
            random.shuffle(examples)
            examples = examples[:num_inspirations]

        # Use REFINE_LABEL for exploitation of best solutions
        label = self.REFINE_LABEL if get_score(parent) > 0 else self.DIVERGE_LABEL
        parent_dict = {label: parent}
        inspiration_programs_dict = {label: examples}

        return parent_dict, inspiration_programs_dict

# EVOLVE-BLOCK-END

