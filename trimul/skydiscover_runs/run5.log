"""
Optimized TriMul using fused projections in bfloat16 and efficient outer product via bmm.
Key optimizations:
1. Fuse all 5 linear projections into one batched matmul to reduce kernel launches
2. Avoid module instantiation overhead - work directly with weight tensors
3. Perform projections in bfloat16 to leverage tensor cores
4. Use bfloat16 for the expensive outer product bmm
5. Minimize dtype conversions and use contiguous layouts
6. Use float32 for LayerNorm stability, bfloat16 for matmuls
"""

import torch
import torch.nn.functional as F


def custom_kernel(data):
    """
    TriMul: LayerNorm(fp32) -> fused 5-way projection(bf16) -> sigmoid gating
    -> masked outer product via bmm(bf16) -> output LayerNorm(fp32) -> gate -> project(bf16).
    Projections fused into single matmul in bfloat16; outer product as batched matmul.
    """
    input_tensor, mask, weights, config = data

    # Load norm weights in float32 for numerical stability
    norm_w = weights['norm.weight'].to(torch.float32)
    norm_b = weights['norm.bias'].to(torch.float32)
    out_norm_w = weights['to_out_norm.weight'].to(torch.float32)
    out_norm_b = weights['to_out_norm.bias'].to(torch.float32)

    # Load projection weights in bfloat16 for tensor core utilization
    left_proj_w  = weights['left_proj.weight'].to(torch.bfloat16)
    right_proj_w = weights['right_proj.weight'].to(torch.bfloat16)
    left_gate_w  = weights['left_gate.weight'].to(torch.bfloat16)
    right_gate_w = weights['right_gate.weight'].to(torch.bfloat16)
    out_gate_w   = weights['out_gate.weight'].to(torch.bfloat16)
    to_out_w     = weights['to_out.weight'].to(torch.bfloat16)

    bs, seqlen, _, dim = input_tensor.shape
    hidden_dim = left_proj_w.shape[0]

    # LayerNorm in float32 for stability
    x_f32 = F.layer_norm(input_tensor.to(torch.float32), [dim], norm_w, norm_b)

    # Convert to bfloat16 for tensor core matmuls
    x_bf16 = x_f32.to(torch.bfloat16)

    # Fuse all 5 projections into single matmul: [5*hidden, dim]
    fused_w = torch.cat([left_proj_w, right_proj_w, left_gate_w, right_gate_w, out_gate_w], dim=0)
    x_flat = x_bf16.reshape(-1, dim)
    fused_out = F.linear(x_flat, fused_w).reshape(bs, seqlen, seqlen, 5 * hidden_dim)

    # Split projections (all in bfloat16)
    left       = fused_out[..., :hidden_dim]
    right      = fused_out[..., hidden_dim:2*hidden_dim]
    left_gate  = fused_out[..., 2*hidden_dim:3*hidden_dim]
    right_gate = fused_out[..., 3*hidden_dim:4*hidden_dim]
    out_gate   = fused_out[..., 4*hidden_dim:5*hidden_dim]

    # Apply mask and sigmoid gates in bfloat16
    mask_exp = mask.unsqueeze(-1).to(torch.bfloat16)
    left  = left  * mask_exp * torch.sigmoid(left_gate)
    right = right * mask_exp * torch.sigmoid(right_gate)
    out_gate_sig = torch.sigmoid(out_gate)

    # Outer product via bmm in bfloat16:
    # left:  [bs, i, k, d] -> permute -> [bs*d, i, k]
    # right: [bs, j, k, d] -> permute -> [bs*d, k, j]
    left_p  = left.permute(0, 3, 1, 2).reshape(bs * hidden_dim, seqlen, seqlen)
    right_p = right.permute(0, 3, 2, 1).reshape(bs * hidden_dim, seqlen, seqlen)

    # bmm: [bs*hidden, i, k] x [bs*hidden, k, j] -> [bs*hidden, i, j]
    out_bf = torch.bmm(left_p, right_p).reshape(bs, hidden_dim, seqlen, seqlen).permute(0, 2, 3, 1)

    # Output LayerNorm in float32 for stability
    out = F.layer_norm(out_bf.to(torch.float32), [hidden_dim], out_norm_w, out_norm_b)

    # Apply output gate and project in bfloat16
    out = out.to(torch.bfloat16) * out_gate_sig
    out = F.linear(out, to_out_w)

    return out.to(torch.float32)
