"""
Optimized TriMul using fused projections and efficient batched matmul for outer product.
Key optimizations:
1. Fuse left_proj+left_gate and right_proj+right_gate into single matmuls
2. Use bfloat16 for compute-heavy ops
3. Outer product via permute+reshape+bmm: reshape (bs,s,s,d) to (bs*d, s, k) and use bmm
4. Minimize memory allocations and kernel launches
"""

import torch
from torch import nn
import torch.nn.functional as F


def trimul_forward_functional(
    x: torch.Tensor,
    mask: torch.Tensor,
    norm_w: torch.Tensor,
    norm_b: torch.Tensor,
    left_fused_w: torch.Tensor,   # [2*hidden_dim, dim]
    right_fused_w: torch.Tensor,  # [2*hidden_dim, dim]
    out_gate_w: torch.Tensor,     # [hidden_dim, dim]
    to_out_norm_w: torch.Tensor,
    to_out_norm_b: torch.Tensor,
    to_out_w: torch.Tensor,       # [dim, hidden_dim]
    dim: int,
    hidden_dim: int,
) -> torch.Tensor:
    """
    Functional TriMul forward:
    1. LayerNorm input (float32)
    2. Fused linear for left (proj+gate) and right (proj+gate) via single matmul each
    3. Apply mask and sigmoid gates
    4. Outer product via permute+reshape+bmm: (bs,i,k,d)->(bs*d,i,k) bmm (bs*d,k,j)
    5. Output LayerNorm, gate, projection
    """
    bs, seq_len, seq_len2, _ = x.shape

    # LayerNorm in float32
    x_norm = F.layer_norm(x, [dim], norm_w, norm_b)

    # Reshape for matmul: (bs*s*s, dim)
    x_flat = x_norm.reshape(-1, dim)

    # Fused left: proj + gate in one matmul -> (bs*s*s, 2*hidden_dim)
    left_fused = F.linear(x_flat, left_fused_w)  # no bias
    left_proj = left_fused[:, :hidden_dim]
    left_gate_val = torch.sigmoid(left_fused[:, hidden_dim:])

    # Fused right: proj + gate in one matmul -> (bs*s*s, 2*hidden_dim)
    right_fused = F.linear(x_flat, right_fused_w)  # no bias
    right_proj = right_fused[:, :hidden_dim]
    right_gate_val = torch.sigmoid(right_fused[:, hidden_dim:])

    # Apply mask and gates
    # mask: (bs, s, s) -> (bs*s*s, 1)
    mask_flat = mask.reshape(-1, 1).float()

    left_act = (left_proj * left_gate_val * mask_flat).reshape(bs, seq_len, seq_len, hidden_dim)
    right_act = (right_proj * right_gate_val * mask_flat).reshape(bs, seq_len, seq_len, hidden_dim)

    # out_gate from x_flat
    out_gate_val = torch.sigmoid(F.linear(x_flat, out_gate_w)).reshape(bs, seq_len, seq_len, hidden_dim)

    # Outer product: '... i k d, ... j k d -> ... i j d'
    # left_act: (bs, i, k, d), right_act: (bs, j, k, d)
    # Permute to (bs, d, i, k) and (bs, d, k, j) then bmm
    # -> (bs*d, i, k) @ (bs*d, k, j) = (bs*d, i, j)
    # Then reshape to (bs, i, j, d)
    left_bf = left_act.to(torch.bfloat16)
    right_bf = right_act.to(torch.bfloat16)

    # (bs, i, k, d) -> (bs, d, i, k)
    left_perm = left_bf.permute(0, 3, 1, 2).contiguous()
    # (bs, j, k, d) -> (bs, d, k, j)
    right_perm = right_bf.permute(0, 3, 2, 1).contiguous()

    # Reshape to (bs*d, i, k) and (bs*d, k, j)
    left_mat = left_perm.reshape(bs * hidden_dim, seq_len, seq_len)
    right_mat = right_perm.reshape(bs * hidden_dim, seq_len, seq_len)

    # bmm: (bs*d, i, k) @ (bs*d, k, j) = (bs*d, i, j)
    out_mat = torch.bmm(left_mat, right_mat)

    # Reshape back: (bs*d, i, j) -> (bs, d, i, j) -> (bs, i, j, d)
    out = out_mat.reshape(bs, hidden_dim, seq_len, seq_len).permute(0, 2, 3, 1).contiguous().float()

    # Output LayerNorm, gate, projection
    out = F.layer_norm(out, [hidden_dim], to_out_norm_w, to_out_norm_b)
    out = out * out_gate_val
    out = F.linear(out, to_out_w)

    return out


def custom_kernel(data):
    """Entry point: unpacks data and calls functional TriMul forward."""
    input_tensor, mask, weights, config = data
    dim = config["dim"]
    hidden_dim = config["hidden_dim"]
    device = input_tensor.device

    # Load weights as float32
    norm_w = weights['norm.weight'].to(torch.float32, device=device)
    norm_b = weights['norm.bias'].to(torch.float32, device=device)
    left_proj_w = weights['left_proj.weight'].to(torch.float32, device=device)
    right_proj_w = weights['right_proj.weight'].to(torch.float32, device=device)
    left_gate_w = weights['left_gate.weight'].to(torch.float32, device=device)
    right_gate_w = weights['right_gate.weight'].to(torch.float32, device=device)
    out_gate_w = weights['out_gate.weight'].to(torch.float32, device=device)
    to_out_norm_w = weights['to_out_norm.weight'].to(torch.float32, device=device)
    to_out_norm_b = weights['to_out_norm.bias'].to(torch.float32, device=device)
    to_out_w = weights['to_out.weight'].to(torch.float32, device=device)

    # Fuse left_proj and left_gate weights: [2*hidden_dim, dim]
    left_fused_w = torch.cat([left_proj_w, left_gate_w], dim=0)
    # Fuse right_proj and right_gate weights: [2*hidden_dim, dim]
    right_fused_w = torch.cat([right_proj_w, right_gate_w], dim=0)

    output = trimul_forward_functional(
        input_tensor.float(),
        mask,
        norm_w, norm_b,
        left_fused_w,
        right_fused_w,
        out_gate_w,
        to_out_norm_w, to_out_norm_b,
        to_out_w,
        dim, hidden_dim,
    )

    return output.float()
