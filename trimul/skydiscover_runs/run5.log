"""
Optimized TriMul kernel using fused projections, bfloat16 compute,
and efficient batched matmul for the outer product step.
Fuses left/gate projections into single matmuls to reduce kernel launches.
"""

import torch
from torch import nn
import torch.nn.functional as F


def trimul_forward(
    x: torch.Tensor,
    mask: torch.Tensor,
    norm_w: torch.Tensor,
    norm_b: torch.Tensor,
    # Fused weight: [2*hidden_dim, dim] for left_proj + left_gate
    left_fused_w: torch.Tensor,
    # Fused weight: [2*hidden_dim, dim] for right_proj + right_gate
    right_fused_w: torch.Tensor,
    out_gate_w: torch.Tensor,
    to_out_norm_w: torch.Tensor,
    to_out_norm_b: torch.Tensor,
    to_out_w: torch.Tensor,
    dim: int,
    hidden_dim: int,
) -> torch.Tensor:
    """
    Forward pass for TriMul:
    1. LayerNorm input
    2. Fused linear for left (proj+gate) and right (proj+gate)
    3. Apply mask, sigmoid gates
    4. Outer product via batched matmul (reshape trick)
    5. Output LayerNorm, gate, projection
    """
    bs, seq_len, seq_len2, _ = x.shape

    # LayerNorm
    x_norm = F.layer_norm(x, [dim], norm_w, norm_b)

    # Reshape for batched linear: (bs*seq*seq, dim)
    x_flat = x_norm.reshape(-1, dim)

    # Fused left projection + gate: (bs*seq*seq, 2*hidden_dim)
    left_fused = F.linear(x_flat, left_fused_w)
    left_proj = left_fused[:, :hidden_dim]
    left_gate = left_fused[:, hidden_dim:].sigmoid()

    # Fused right projection + gate: (bs*seq*seq, 2*hidden_dim)
    right_fused = F.linear(x_flat, right_fused_w)
    right_proj = right_fused[:, :hidden_dim]
    right_gate = right_fused[:, hidden_dim:].sigmoid()

    # Out gate
    out_gate = F.linear(x_flat, out_gate_w).sigmoid()

    # Apply mask: mask is (bs, seq, seq) -> (bs*seq*seq, 1)
    mask_flat = mask.reshape(-1, 1).float()

    left = (left_proj * mask_flat * left_gate).reshape(bs, seq_len, seq_len2, hidden_dim)
    right = (right_proj * mask_flat * right_gate).reshape(bs, seq_len, seq_len2, hidden_dim)
    out_gate = out_gate.reshape(bs, seq_len, seq_len2, hidden_dim)

    # Outer product: left[b,i,k,d] * right[b,j,k,d] -> out[b,i,j,d]
    # Reshape: left -> (bs*d, i, k), right -> (bs*d, j, k)
    # Then batched matmul: (bs*d, i, k) x (bs*d, k, j) -> (bs*d, i, j)
    # Use bf16 for speed
    left_bf16 = left.to(torch.bfloat16)
    right_bf16 = right.to(torch.bfloat16)

    # Permute: (bs, i, k, d) -> (bs, d, i, k)
    left_t = left_bf16.permute(0, 3, 1, 2).reshape(bs * hidden_dim, seq_len, seq_len2)
    right_t = right_bf16.permute(0, 3, 2, 1).reshape(bs * hidden_dim, seq_len2, seq_len)

    # (bs*d, i, k) @ (bs*d, k, j) -> (bs*d, i, j)
    out_raw = torch.bmm(left_t, right_t)  # (bs*hidden_dim, seq_len, seq_len)

    # Reshape back: (bs, hidden_dim, i, j) -> (bs, i, j, hidden_dim)
    out = out_raw.reshape(bs, hidden_dim, seq_len, seq_len).permute(0, 2, 3, 1).to(torch.float32)

    # Output norm + gate + projection
    out = F.layer_norm(out, [hidden_dim], to_out_norm_w, to_out_norm_b)
    out = out * out_gate
    out = F.linear(out, to_out_w)

    return out


# Cache for pre-processed weights
_weight_cache = {}


def custom_kernel(data):
    """
    TriMul forward with fused projections and efficient outer product.
    Caches fused weight tensors to avoid recomputation across calls.
    """
    input_tensor, mask, weights, config = data
    dim = config["dim"]
    hidden_dim = config["hidden_dim"]
    device = input_tensor.device

    # Build a cache key from weight data pointer (stable across calls with same weights)
    cache_key = (
        weights['left_proj.weight'].data_ptr(),
        weights['right_proj.weight'].data_ptr(),
        dim,
        hidden_dim,
    )

    if cache_key not in _weight_cache:
        # Fuse left_proj + left_gate into single weight matrix
        left_fused_w = torch.cat([
            weights['left_proj.weight'].to(torch.float32),
            weights['left_gate.weight'].to(torch.float32),
        ], dim=0).to(device)

        right_fused_w = torch.cat([
            weights['right_proj.weight'].to(torch.float32),
            weights['right_gate.weight'].to(torch.float32),
        ], dim=0).to(device)

        _weight_cache[cache_key] = {
            'norm_w': weights['norm.weight'].to(torch.float32).to(device),
            'norm_b': weights['norm.bias'].to(torch.float32).to(device),
            'left_fused_w': left_fused_w,
