        right = (right * m).mul_(torch.sigmoid(right_gate))

        out = einsum('... i k d, ... j k d -> ... i j d',
                     left, right).to(torch.float32)

        out = self.to_out_norm(out)
        out = out.mul_(torch.sigmoid(out_gate.to(torch.float32)))
        return torch.nn.functional.linear(out.to(torch.bfloat16),
