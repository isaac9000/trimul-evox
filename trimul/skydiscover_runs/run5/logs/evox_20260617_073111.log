        right = right * mask * torch.sigmoid(right_gate)

        # einsum '... i k d, ... j k d -> ... i j d'
        # = for each d (channel): out[i,j] = sum_k left[i,k] * right[j,k]
        # reshape to batched matmul: move d to batch dimension
        # left: (b, i, k, d) -> (b, d, i, k); right: (b, j, k, d) -> (b, d, k, j)
        lb = left.permute(0, 3, 1, 2).to(torch.bfloat16).contiguous()
        rb = right.permute(0, 3, 2, 1).to(torch.bfloat16).contiguous()
        out = torch.matmul(lb, rb)  # (b, d, i, j)
