    out = ob.reshape(bs, hidden_dim, seq_len, seq_len).permute(0, 2, 3, 1).to(torch.float32)

    out = F.layer_norm(out, (hidden_dim,), out_norm_w, out_norm_b)
    out = out * out_gate
    out = torch.matmul(out, to_out_w)
    return out
