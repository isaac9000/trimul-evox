        weights['left_proj.weight'].to(torch.float32),
        weights['right_proj.weight'].to(torch.float32),
        weights['left_gate.weight'].to(torch.float32),
        weights['right_gate.weight'].to(torch.float32),
        weights['out_gate.weight'].to(torch.float32),
    ], dim=0).t().contiguous()  # [dim, 5*hidden_dim]

    out_norm_w = weights['to_out_norm.weight'].to(torch.float32).contiguous()
    out_norm_b = weights['to_out_norm.bias'].to(torch.float32).contiguous()
    to_out_w = weights['to_out.weight'].to(torch.float32).t().contiguous()

