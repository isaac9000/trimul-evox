    to_out_w = weights['to_out.weight'].to(torch.float32).t().contiguous()  # [hidden_dim, dim]

    cached = (norm_w, norm_b, w_cat, out_norm_w, out_norm_b, to_out_w)
    _CACHE[key] = cached
    return cached


def custom_kernel(data):
