    lg = g('left_gate.weight')
    rp = g('right_proj.weight')
    rg = g('right_gate.weight')
    hidden = lp.shape[0]

    c = {
        'norm_w': g('norm.weight'),
        'norm_b': g('norm.bias'),
        'left_cat': torch.cat([lp, lg], dim=0).t().contiguous(),
        'right_cat': torch.cat([rp, rg], dim=0).t().contiguous(),
        'out_gate': g('out_gate.weight').t().contiguous(),
        'on_w': g('to_out_norm.weight'),
        'on_b': g('to_out_norm.bias'),
        'to_out': g('to_out.weight').t().contiguous(),
        'hidden': hidden,
    }
    _CACHE[key] = c
    return c


