    rp = weights['right_proj.weight'].to(device=device, dtype=torch.float32)
    lg = weights['left_gate.weight'].to(device=device, dtype=torch.float32)
    rg = weights['right_gate.weight'].to(device=device, dtype=torch.float32)
    og = weights['out_gate.weight'].to(device=device, dtype=torch.float32)

    # Concatenate all input projections: [5*hidden, dim] -> transposed for matmul
    fused_w = torch.cat([lp, rp, lg, rg, og], dim=0).t().contiguous()
    hidden = lp.shape[0]

    out_norm_w = weights['to_out_norm.weight'].to(device=device, dtype=torch.float32).contiguous()
    out_norm_b = weights['to_out_norm.bias'].to(device=device, dtype=torch.float32).contiguous()
